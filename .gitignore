# Ignore everything by default
/*

# Allow only these
!/.gitignore
!/Makefile
!/experiments/

# Inside experiments — ignore large output dirs and binaries
/experiments/results/
/experiments/results_*/
/experiments/dl_report_complete/
/experiments/extra_figures/
/experiments/__pycache__/
/experiments/.ipynb_checkpoints/
*.pth
*.npy
*.pkl
*.zip
*.pyc
